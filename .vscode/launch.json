{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [                
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}"
        },
        {
            "name": "Python: Openevolve Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/openevolve/openevolve-run.py",
            "args": ["initial_program.py", "evaluator.py", "--config", "./outputs/Airport_output/config_remote.yaml", "--output", "./outputs/Airport_output/openevolve_output"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/problems/triples_to_text"
        },
        {
            "name": "Python: Tripler Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tripler/app.py",
            "args": ["extract", "--input", "inputs/input_data_weather_dev_full.json", "--output", "extracted_triples.json", "--model", "google/gemma-3-270m-it", "--base-url", "http://localhost:8002/v1", "--api-key", "none"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/tripler"
        },
        {
            "name": "Python: Final Test Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/problems/triples_to_text/final_test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/problems/triples_to_text/",
            "env": {
                "CONFIG_PATH": "/home/nikiaker/Projects/studia/stop2/magisterka/d2t/problems/triples_to_text/results/slurm32/outputs/2_sm1ibeyp/Building_output/config_remote.yaml",
                "WEBNLG_DOMAIN": "Building",
                "BEST_PROGRAM_PATH": "/home/nikiaker/Projects/studia/stop2/magisterka/d2t/problems/triples_to_text/results/slurm32/outputs/2_sm1ibeyp/Building_output/openevolve_output/best/best_program.py"
            }
        }
    ]
}
